{
  "name": "stock-chart-app",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "dev:both": "concurrently \"npm run dev\" \"npm run client\"",
    "install:all": "npm install && cd client && npm install",
    "setup": "node setup-data.js",
    "setup:start": "npm run setup && npm start",
    "setup:dev": "npm run setup && npm run dev",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["stock", "chart", "react", "express", "finance"],
  "author": "",
  "license": "ISC",
  "description": "Stock charting application with React frontend and Express backend",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2"
  }
}
